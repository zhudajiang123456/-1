                achievements: "上海市汽车电子芯片工程中心",
                level: "教育部重点实验室",
                website: "#"
            },
            {
                id: 23,
                name: "集成电路学院",
                university: "中国科学院大学",
                type: "national",
                tags: ["微纳加工", "器件物理", "EDA"],
                city: "北京",
                coordinates: [116.3376, 39.9822],
                director: "叶甜春研究员",
                focus: "集成电路制造技术、微纳加工",
                achievements: "微电子研究所、微电子器件与集成技术重点实验室",
                level: "国家重点实验室",
                website: "#"
            },
            {
                id: 24,
                name: "微电子学院",
                university: "南开大学",
                type: "education",
                tags: ["光电子", "半导体", "集成电路"],
                city: "天津",
                coordinates: [117.1713, 39.1092],
                director: "张伟刚教授",
                focus: "光电子器件、半导体材料",
                achievements: "光电子薄膜器件与技术重点实验室",
                level: "教育部重点实验室",
                website: "#"
            },
            {
                id: 25,
                name: "电子信息与电气工程学院",
                university: "山东大学",
                type: "education",
                tags: ["半导体材料", "集成电路", "晶体材料"],
                city: "济南",
                coordinates: [117.0248, 36.6828],
                director: "陶绪堂教授",
                focus: "半导体晶体材料、集成电路",
                achievements: "新一代半导体材料研究院",
                level: "教育部重点实验室",
                website: "#"
            },
            {
                id: 26,
                name: "微电子学院",
                university: "厦门大学",
                type: "education",
                tags: ["半导体", "集成电路", "光伏"],
                city: "厦门",
                coordinates: [118.0964, 24.4393],
                director: "陈忠教授",
                focus: "半导体器件、集成电路设计",
                achievements: "福建省集成电路设计工程技术研究中心",
                level: "省级重点实验室",
                website: "#"
            },
            {
                id: 27,
                name: "电子科学与工程学院",
                university: "大连理工大学",
                type: "education",
                tags: ["集成电路", "微电子", "光电子"],
                city: "大连",
                coordinates: [121.5257, 38.9194],
                director: "赵毅教授",
                focus: "集成电路设计、微电子器件",
                achievements: "辽宁省集成电路技术重点实验室",
                level: "教育部重点实验室",
                website: "#"
            },
            {
                id: 28,
                name: "微电子学院",
                university: "华东师范大学",
                type: "education",
                tags: ["集成电路", "半导体", "通信芯片"],
                city: "上海",
                coordinates: [121.4026, 31.2285],
                director: "石艳玲教授",
                focus: "集成电路设计、通信芯片",
                achievements: "上海市多维度信息处理重点实验室",
                level: "教育部重点实验室",
                website: "#"
            },
            {
                id: 29,
                name: "集成电路学院",
                university: "南方科技大学",
                type: "education",
                tags: ["集成电路", "第三代半导体", "EDA"],
                city: "深圳",
                coordinates: [113.9973, 22.5943],
                director: "于洪宇教授",
                focus: "第三代半导体、集成电路设计",
                achievements: "深港微电子学院",
                level: "教育部重点实验室",
                website: "#"
            },
            {
                id: 30,
                name: "微电子学院",
                university: "杭州电子科技大学",
                type: "provincial",
                tags: ["集成电路设计", "EDA", "射频"],
                city: "杭州",
                coordinates: [120.3486, 30.3188],
                director: "程知群教授",
                focus: "集成电路设计、射频技术",
                achievements: "浙江省集成电路设计重点实验室",
                level: "省级重点实验室",
                website: "#"
            },
            {
                id: 31,
                name: "微电子学院",
                university: "重庆大学",
                type: "education",
                tags: ["功率半导体", "集成电路", "MEMS"],
                city: "重庆",
                coordinates: [106.5516, 29.5630],
                director: "蔡开勇教授",
                focus: "功率半导体、MEMS器件",
                achievements: "重庆市微纳制造与系统集成工程技术研究中心",
                level: "教育部重点实验室",
                website: "#"
            },
            {
                id: 32,
                name: "集成电路学院",
                university: "湖南大学",
                type: "education",
                tags: ["半导体", "集成电路", "功率器件"],
                city: "长沙",
                coordinates: [112.9388, 28.2282],
                director: "刘渊教授",
                focus: "低维半导体器件、集成电路",
                achievements: "国家卓越工程师学院",
                level: "教育部重点实验室",
                website: "#"
            }
        ];

        let selectedLabs = [];
        let currentFilter = 'all';

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            renderLabs(labsData);
            initMap();
            setupFilters();
            setupSearch();
        });

        // Render Lab Cards
        function renderLabs(data) {
            const grid = document.getElementById('labs-grid');
            const count = document.getElementById('lab-count');
            grid.innerHTML = '';
            count.textContent = `共收录 ${data.length} 个实验室`;

            data.forEach((lab, index) => {
                const card = document.createElement('div');
                card.className = 'lab-card glass-card rounded-xl p-6 border border-gray-800 animate-fade-in';
                card.style.animationDelay = `${index * 0.05}s`;
                
                const isNational = lab.level.includes('全国') || lab.level.includes('国家');
                const levelClass = isNational ? 'national-key' : 'tag';
                
                card.innerHTML = `
                    <div class="flex justify-between items-start mb-4">
                        <div class="flex-1">
                            <h3 class="text-lg font-bold text-white mb-1 line-clamp-2">${lab.name}</h3>
                            <p class="text-blue-400 font-medium">${lab.university}</p>
                        </div>
                        <span class="${levelClass} px-2 py-1 rounded text-xs font-medium whitespace-nowrap ml-2">
                            ${lab.level}
                        </span>
                    </div>
                    
                    <div class="space-y-3 mb-4">
                        <div class="flex items-center text-sm text-gray-400">
                            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                            ${lab.city}
                        </div>
                        <div class="flex items-center text-sm text-gray-400">
                            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                            </svg>
                            ${lab.director}
                        </div>
                    </div>

                    <div class="mb-4">
                        <p class="text-sm text-gray-300 line-clamp-2 mb-2">${lab.focus}</p>
                        <p class="text-xs text-gray-500 line-clamp-1">代表成果：${lab.achievements}</p>
                    </div>

                    <div class="flex flex-wrap gap-2 mb-4">
                        ${lab.tags.map(tag => `<span class="text-xs bg-gray-800 text-gray-300 px-2 py-1 rounded">${tag}</span>`).join('')}
                    </div>

                    <div class="flex gap-2 pt-4 border-t border-gray-800">
                        <button onclick="toggleLabSelection(${lab.id})" 
                                class="flex-1 py-2 rounded-lg text-sm font-medium transition ${selectedLabs.includes(lab.id) ? 'bg-green-600 text-white' : 'bg-gray-800 text-gray-300 hover:bg-gray-700'}">
                            ${selectedLabs.includes(lab.id) ? '已选择' : '加入对比'}
                        </button>
                        <a href="${lab.website}" target="_blank" 
                           class="px-4 py-2 rounded-lg text-sm font-medium bg-blue-600 hover:bg-blue-700 text-white transition">
                            访问官网
                        </a>
                    </div>
                `;
                grid.appendChild(card);
            });
        }

        // Setup Filters
        function setupFilters() {
            const buttons = document.querySelectorAll('.filter-btn');
            buttons.forEach(btn => {
                btn.addEventListener('click', function() {
                    buttons.forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    
                    const filter = this.dataset.filter;
                    currentFilter = filter;
                    
                    let filtered = labsData;
                    if (filter === 'national') {
                        filtered = labsData.filter(lab => lab.level.includes('全国') || lab.level.includes('国家'));
                    } else if (filter === 'design') {
                        filtered = labsData.filter(lab => lab.tags.some(t => ['集成电路设计', 'EDA', 'SoC', '数字电路'].includes(t)));
                    } else if (filter === 'device') {
                        filtered = labsData.filter(lab => lab.tags.some(t => ['器件', '半导体器件', '功率器件'].includes(t)));
                    } else if (filter === 'material') {
                        filtered = labsData.filter(lab => lab.tags.some(t => ['宽禁带', '半导体材料', '硅基', '材料'].includes(t)));
                    } else if (filter === 'process') {
                        filtered = labsData.filter(lab => lab.tags.some(t => ['工艺', '制造', '微纳加工', 'MEMS'].includes(t)));
                    }
                    
                    renderLabs(filtered);
                });
            });
        }

        // Setup Search
        function setupSearch() {
            const searchInput = document.getElementById('search-input');
            searchInput.addEventListener('input', function(e) {
                const query = e.target.value.toLowerCase();
                const filtered = labsData.filter(lab => 
                    lab.name.toLowerCase().includes(query) || 
                    lab.university.toLowerCase().includes(query) ||
                    lab.city.toLowerCase().includes(query)
                );
                renderLabs(filtered);
            });
        }

        // Toggle Lab Selection for Comparison
        function toggleLabSelection(id) {
            const index = selectedLabs.indexOf(id);
            if (index > -1) {
                selectedLabs.splice(index, 1);
            } else {
                if (selectedLabs.length >= 3) {
                    alert('最多可同时对比3个实验室');
                    return;
                }
                selectedLabs.push(id);
            }
            renderLabs(currentFilter === 'all' ? labsData : labsData.filter(lab => {
                if (currentFilter === 'national') return lab.level.includes('全国') || lab.level.includes('国家');
                // Add other filter logic if needed
                return true;
            }));
        }

        // Toggle Compare Modal
        function toggleCompare() {
            const modal = document.getElementById('compare-modal');
            const content = document.getElementById('compare-content');
            
            if (modal.classList.contains('hidden')) {
                modal.classList.remove('hidden');
                updateCompareContent();
            } else {
                modal.classList.add('hidden');
            }
        }

        // Update Compare Content
        function updateCompareContent() {
            const content = document.getElementById('compare-content');
            if (selectedLabs.length === 0) {
                content.innerHTML = '<p class="text-center text-gray-500 mt-20">请在实验室卡片中点击"加入对比"选择要比较的实验室（最多3个）</p>';
                return;
            }

            const selected = labsData.filter(lab => selectedLabs.includes(lab.id));
            const rows = ['university', 'level', 'director', 'city', 'focus', 'achievements', 'tags'];
            const rowNames = {
                university: '所属高校',
                level: '平台等级',
                director: '负责人',
                city: '所在城市',
                focus: '研究方向',
                achievements: '代表成果',
                tags: '技术标签'
            };

            let html = '<div class="overflow-x-auto"><table class="w-full text-left border-collapse">';
            
            // Header
            html += '<tr class="border-b border-gray-700"><th class="p-4 text-gray-400 font-medium">对比项</th>';
            selected.forEach(lab => {
                html += `<th class="p-4 text-white font-bold min-w-[200px]">${lab.name}</th>`;
            });
            html += '</tr>';

            // Rows
            rows.forEach(row => {
                html += `<tr class="border-b border-gray-800 hover:bg-gray-800/50"><td class="p-4 text-gray-400 font-medium">${rowNames[row]}</td>`;
                selected.forEach(lab => {
                    let value = lab[row];
                    if (row === 'tags') value = value.join(', ');
                    html += `<td class="p-4 text-gray-300">${value}</td>`;
                });
                html += '</tr>';
            });

            html += '</table></div>';
            content.innerHTML = html;
        }

        // Initialize ECharts Map
        function initMap() {
            const chartDom = document.getElementById('map-container');
            const myChart = echarts.init(chartDom);
            
            // Group labs by city
            const cityData = {};
            labsData.forEach(lab => {
                if (!cityData[lab.city]) {
                    cityData[lab.city] = [];
                }
                cityData[lab.city].push(lab);
            });

            const data = Object.keys(cityData).map(city => {
                const labs = cityData[city];
                const firstLab = labs[0];
                return {
                    name: city,
                    value: [...firstLab.coordinates, labs.length],
                    labs: labs
                };
            });

            const option = {
                backgroundColor: 'transparent',
                tooltip: {
                    trigger: 'item',
                    backgroundColor: 'rgba(30, 30, 30, 0.9)',
                    borderColor: '#444',
                    textStyle: { color: '#fff' },
                    formatter: function(params) {
                        const labs = params.data.labs;
                        let html = `<div class="font-bold mb-2">${params.name} (${labs.length}个实验室)</div>`;
                        labs.forEach(lab => {
                            const isNational = lab.level.includes('全国') || lab.level.includes('国家');
                            const color = isNational ? '#ef4444' : '#3b82f6';
                            html += `<div class="text-sm mb-1"><span style="color:${color}">●</span> ${lab.name}</div>`;
                        });
                        return html;
                    }
                },
                geo: {
                    map: 'china',
                    roam: true,
                    zoom: 1.2,
                    center: [105, 36],
                    itemStyle: {
                        areaColor: 'rgba(255, 255, 255, 0.05)',
                        borderColor: 'rgba(255, 255, 255, 0.2)',
                        borderWidth: 1
                    },
                    emphasis: {
                        itemStyle: {
                            areaColor: 'rgba(102, 126, 234, 0.3)'
                        }
                    }
                },
                series: [
                    {
                        type: 'scatter',
                        coordinateSystem: 'geo',
                        data: data,
                        symbolSize: function(val) {
                            return Math.max(val[2] * 8, 12);
                        },
                        label: {
                            show: true,
                            formatter: '{b}',
                            position: 'right',
                            color: '#fff',
                            fontSize: 10
                        },
                        itemStyle: {
                            color: function(params) {
                                const hasNational = params.data.labs.some(l => l.level.includes('全国') || l.level.includes('国家'));
                                return hasNational ? '#ef4444' : '#3b82f6';
                            },
                            shadowBlur: 10,
                            shadowColor: 'rgba(0, 0, 0, 0.5)'
                        },
                        emphasis: {
                            scale: 1.5,
                            label: { show: true }
                        }
                    }
                ]
            };

            // Load China map
            fetch('https://geo.datav.aliyun.com/areas_v3/bound/100000_full.json')
                .then(response => response.json())
                .then(geoJson => {
                    echarts.registerMap('china', geoJson);
                    myChart.setOption(option);
                })
                .catch(() => {
                    // Fallback if map data fails to load
                    chartDom.innerHTML = '<div class="flex items-center justify-center h-full text-gray-500">地图加载中...</div>';
                });

            window.addEventListener('resize', () => myChart.resize());
        }
    </script>
</body>
</html>
