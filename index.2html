<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>芯图 - 中国顶尖高校芯片实验室聚合平台</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/echarts/5.4.3/echarts.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', 'Noto Sans SC', sans-serif;
            background: #0a0a0a;
            color: #e5e5e5;
        }
        .gradient-text {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .lab-card {
            transition: all 0.3s ease;
        }
        .lab-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(102, 126, 234, 0.2);
            border-color: rgba(102, 126, 234, 0.5);
        }
        .tag {
            background: rgba(102, 126, 234, 0.2);
            border: 1px solid rgba(102, 126, 234, 0.3);
        }
        .national-key {
            background: rgba(239, 68, 68, 0.2);
            border: 1px solid rgba(239, 68, 68, 0.4);
            color: #fca5a5;
        }
        .filter-btn.active {
            background: #667eea;
            color: white;
        }
        #map-container {
            height: 500px;
            width: 100%;
        }
        .scroll-hidden::-webkit-scrollbar {
            display: none;
        }
        .animate-fade-in {
            animation: fadeIn 0.5s ease-in;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body class="min-h-screen bg-gradient-to-br from-gray-900 via-black to-gray-900">

    <!-- Navigation -->
    <nav class="fixed w-full z-50 glass-card border-b border-gray-800">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center space-x-3">
                    <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-purple-600 rounded-lg flex items-center justify-center">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/>
                        </svg>
                    </div>
                    <span class="text-xl font-bold tracking-tight">芯图 <span class="text-gray-400 text-sm font-normal">ChipMap</span></span>
                </div>
                <div class="hidden md:flex space-x-8">
                    <a href="#labs" class="text-gray-300 hover:text-white transition">实验室</a>
                    <a href="#map" class="text-gray-300 hover:text-white transition">分布地图</a>
                    <a href="#stats" class="text-gray-300 hover:text-white transition">数据统计</a>
                    <button onclick="toggleCompare()" class="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg text-sm font-medium transition">对比实验室</button>
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="pt-32 pb-20 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
        <div class="text-center space-y-8">
            <h1 class="text-5xl md:text-7xl font-bold tracking-tight">
                探索中国顶尖<br>
                <span class="gradient-text">芯片设计实验室</span>
            </h1>
            <p class="max-w-2xl mx-auto text-xl text-gray-400 leading-relaxed">
                聚合全国211及以上高校集成电路、微电子、半导体领域重点实验室，<br>
                涵盖国家重点实验室、工程研究中心及前沿科研平台
            </p>
            <div class="flex justify-center gap-4 text-sm text-gray-500">
                <span class="flex items-center gap-2"><div class="w-2 h-2 bg-red-500 rounded-full"></div>全国重点实验室</span>
                <span class="flex items-center gap-2"><div class="w-2 h-2 bg-blue-500 rounded-full"></div>教育部重点实验室</span>
                <span class="flex items-center gap-2"><div class="w-2 h-2 bg-green-500 rounded-full"></div>国家工程研究中心</span>
            </div>
        </div>
    </section>

    <!-- Filters -->
    <section class="sticky top-16 z-40 glass-card border-y border-gray-800 py-4 mb-8">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-wrap gap-3 items-center justify-between">
                <div class="flex flex-wrap gap-2" id="filter-container">
                    <button class="filter-btn active px-4 py-2 rounded-full text-sm font-medium bg-gray-800 text-gray-300 hover:bg-gray-700 transition" data-filter="all">全部</button>
                    <button class="filter-btn px-4 py-2 rounded-full text-sm font-medium bg-gray-800 text-gray-300 hover:bg-gray-700 transition" data-filter="national">全国重点实验室</button>
                    <button class="filter-btn px-4 py-2 rounded-full text-sm font-medium bg-gray-800 text-gray-300 hover:bg-gray-700 transition" data-filter="design">集成电路设计</button>
                    <button class="filter-btn px-4 py-2 rounded-full text-sm font-medium bg-gray-800 text-gray-300 hover:bg-gray-700 transition" data-filter="device">半导体器件</button>
                    <button class="filter-btn px-4 py-2 rounded-full text-sm font-medium bg-gray-800 text-gray-300 hover:bg-gray-700 transition" data-filter="material">宽禁带半导体</button>
                    <button class="filter-btn px-4 py-2 rounded-full text-sm font-medium bg-gray-800 text-gray-300 hover:bg-gray-700 transition" data-filter="process">工艺与制造</button>
                </div>
                <div class="relative">
                    <input type="text" id="search-input" placeholder="搜索学校或实验室..." 
                           class="bg-gray-800 border border-gray-700 rounded-full px-4 py-2 pl-10 text-sm focus:outline-none focus:border-blue-500 w-64">
                    <svg class="w-4 h-4 text-gray-500 absolute left-3 top-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                </div>
            </div>
        </div>
    </section>

    <!-- Map Visualization -->
    <section id="map" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
        <div class="glass-card rounded-2xl p-6 border border-gray-800">
            <h2 class="text-2xl font-bold mb-4 flex items-center gap-2">
                <svg class="w-6 h-6 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                实验室地理分布
            </h2>
            <div id="map-container" class="rounded-xl overflow-hidden bg-gray-900"></div>
        </div>
    </section>

    <!-- Labs Grid -->
    <section id="labs" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
        <div class="flex justify-between items-center mb-8">
            <h2 class="text-3xl font-bold">实验室详情</h2>
            <span id="lab-count" class="text-gray-400 text-sm">共收录 32 个实验室</span>
        </div>
        
        <div id="labs-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- Lab cards will be injected here by JavaScript -->
        </div>
    </section>

    <!-- Statistics -->
    <section id="stats" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="glass-card rounded-2xl p-6 border border-gray-800">
                <div class="text-3xl font-bold text-blue-400 mb-2">32+</div>
                <div class="text-gray-400">收录实验室</div>
                <div class="text-xs text-gray-600 mt-2">覆盖985/211顶尖高校</div>
            </div>
            <div class="glass-card rounded-2xl p-6 border border-gray-800">
                <div class="text-3xl font-bold text-purple-400 mb-2">15</div>
                <div class="text-gray-400">全国重点实验室</div>
                <div class="text-xs text-gray-600 mt-2">集成电路领域核心平台</div>
            </div>
            <div class="glass-card rounded-2xl p-6 border border-gray-800">
                <div class="text-3xl font-bold text-green-400 mb-2">8</div>
                <div class="text-gray-400">主要城市</div>
                <div class="text-xs text-gray-600 mt-2">北京、上海、西安、成都等</div>
            </div>
        </div>
    </section>

    <!-- Compare Modal -->
    <div id="compare-modal" class="fixed inset-0 z-50 hidden">
        <div class="absolute inset-0 bg-black bg-opacity-80 backdrop-blur-sm" onclick="toggleCompare()"></div>
        <div class="absolute inset-x-4 top-20 bottom-20 md:inset-x-20 bg-gray-900 rounded-2xl border border-gray-700 overflow-hidden flex flex-col">
            <div class="p-6 border-b border-gray-800 flex justify-between items-center">
                <h3 class="text-2xl font-bold">实验室对比</h3>
                <button onclick="toggleCompare()" class="text-gray-400 hover:text-white">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
            <div class="flex-1 overflow-auto p-6" id="compare-content">
                <p class="text-center text-gray-500 mt-20">请在实验室卡片中点击"加入对比"选择要比较的实验室</p>
            </div>
        </div>
    </div>

